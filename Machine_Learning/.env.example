# Environment Configuration Template
# Copy this to .env and fill in your values (DO NOT COMMIT .env)

# ============================================================================
# PATHS & DIRECTORIES
# ============================================================================

# Input data
DATA_RAW_PATH="data/raw/traffic_ml_ready.parquet"

# Output directories
DATA_OUTPUT_DIR="data/outputs"
DATA_MODELS_DIR="data/models"
REPORTS_DIR="reports"
LOGS_DIR="logs"

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"
LOG_FILE="logs/ml_tfm.log"

# ============================================================================
# MODELING PARAMETERS (override config.yaml if needed)
# ============================================================================

# Random seed for reproducibility
RANDOM_STATE=42

# Model selection: logistic_regression, random_forest, xgboost
# Leave empty to train all
SELECTED_MODEL=""

# CV folds
CV_FOLDS=5

# Parallelization (number of CPU cores, -1 for all)
N_JOBS=-1

# ============================================================================
# CLOUD / EXTERNAL SERVICES (Optional)
# ============================================================================

# AWS S3 (if data is in cloud)
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your_key_here"
# AWS_SECRET_ACCESS_KEY="your_secret_here"
# S3_BUCKET="your-bucket"

# Database (for scoring/monitoring)
# DB_HOST="localhost"
# DB_PORT=5432
# DB_USER="postgres"
# DB_PASSWORD="your_password"
# DB_NAME="network_monitoring"

# ============================================================================
# FEATURE & TARGET CONFIGURATION
# ============================================================================

# Utilization threshold (%) for event definition
UTILIZATION_THRESHOLD=70.0

# Prediction horizon (days)
HORIZON_DAYS=30

# Cardinality reduction: categories with freq < this get grouped to 'OTHER'
MIN_CATEGORY_FREQ=20

# Classification threshold (probability cutoff for 0/1 prediction)
CLASSIFICATION_THRESHOLD=0.70

# ============================================================================
# DEVELOPMENT / DEBUG
# ============================================================================

# Reduces dataset size for testing (0.0-1.0, 1.0=full dataset)
DEBUG_SAMPLE_FRACTION=1.0

# Enable validation plots during preprocessing
DEBUG_VALIDATION_PLOTS=false

# Verbose output
VERBOSE=true
